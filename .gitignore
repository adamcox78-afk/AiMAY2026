ruvector.db
.claude/memory.db
.claude-flow/daemon-state.json
.claude-flow/daemon.pid
.claude-flow/swarm/
.claude-flow/metrics/codebase-map.json
.claude-flow/metrics/security-audit.json

# Dependencies & logs
node_modules/
*.log

# Next.js / build output
.next/
/out/
/build
next-env.d.ts
*.tsbuildinfo

# Env files (never commit secrets) — .env.example is intentionally tracked
.env
.env*.local

# Vercel / OS
.vercel
.DS_Store
