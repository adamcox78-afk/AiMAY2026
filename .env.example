# ─────────────────────────────────────────────────────────────────────────────
# Apex Signal — environment configuration
# Copy to `.env.local` and fill in. EVERY value is optional for the MVP:
# with no keys set, the app runs on deterministic mock data end-to-end.
# ─────────────────────────────────────────────────────────────────────────────

# Data mode: "mock" (default) or "live". "live" requires the provider keys below.
APEX_DATA_MODE=mock

# --- Supabase (persistence) -------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Market data providers --------------------------------------------------
POLYGON_API_KEY=
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# --- Prediction markets -----------------------------------------------------
KALSHI_API_KEY=
KALSHI_API_SECRET=
POLYMARKET_API_KEY=

# --- News & sentiment -------------------------------------------------------
NEWS_API_KEY=
SOCIAL_SENTIMENT_API_KEY=

# --- Ruflo (automation / scheduling / alerting) -----------------------------
# Shared secret the Ruflo daemon presents when calling /api/ruflo/* endpoints.
RUFLO_WEBHOOK_SECRET=dev-ruflo-secret-change-me
RUFLO_BASE_URL=http://localhost:3000

# --- Higgsfield (visual intelligence / video generation) --------------------
HIGGSFIELD_API_KEY=
HIGGSFIELD_PROJECT_ID=

# --- Alert channels ---------------------------------------------------------
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TELEGRAM_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
